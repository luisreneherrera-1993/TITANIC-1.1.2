"""
Streamlit App — Titanic ML Project
Modelos: Regresión Logística (Supervivencia) + Regresión Lineal (Tarifa)
CRISP-ML(Q) · Etapa de Despliegue (Deployment)

Ejecución:
    streamlit run app.py
"""

import streamlit as st
import pandas as pd
import numpy as np
import pickle
import os

# ----------------------------------------------------------------------------
# Configuración de la página
# ----------------------------------------------------------------------------
st.set_page_config(
    page_title="Titanic ML — Predicción de Supervivencia y Tarifa",
    page_icon="🚢",
    layout="wide",
    initial_sidebar_state="expanded",
)

BASE_DIR = os.path.dirname(os.path.abspath(__file__))

# Se prueban varias rutas posibles, para que el archivo funcione tanto dentro
# de la estructura completa del proyecto (app/app.py + ../models) como si se
# ejecuta de forma suelta (app.py + ./models en el mismo directorio).
CANDIDATE_MODEL_DIRS = [
    os.path.join(BASE_DIR, "..", "models"),
    os.path.join(BASE_DIR, "models"),
    os.path.join(BASE_DIR),
    os.path.join(os.getcwd(), "models"),
]


def _find_models_dir():
    for d in CANDIDATE_MODEL_DIRS:
        clf_path = os.path.join(d, "logistic_survival_model.pkl")
        reg_path = os.path.join(d, "linear_fare_model.pkl")
        if os.path.exists(clf_path) and os.path.exists(reg_path):
            return d
    return None


@st.cache_resource
def load_models():
    models_dir = _find_models_dir()
    if models_dir is None:
        raise FileNotFoundError("No se encontraron los archivos .pkl de los modelos.")
    clf_path = os.path.join(models_dir, "logistic_survival_model.pkl")
    reg_path = os.path.join(models_dir, "linear_fare_model.pkl")
    with open(clf_path, "rb") as f:
        clf_model = pickle.load(f)
    with open(reg_path, "rb") as f:
        reg_model = pickle.load(f)
    return clf_model, reg_model


# ----------------------------------------------------------------------------
# Estilos
# ----------------------------------------------------------------------------
st.markdown(
    """
    <style>
    .main-header {
        font-size: 2.4rem;
        font-weight: 800;
        color: #0f4c5c;
        margin-bottom: 0;
    }
    .sub-header {
        font-size: 1.05rem;
        color: #566573;
        margin-top: 0;
    }
    .metric-card {
        background-color: #f4f9fb;
        border-radius: 10px;
        padding: 1rem;
        border-left: 5px solid #0f4c5c;
    }
    </style>
    """,
    unsafe_allow_html=True,
)

st.markdown('<p class="main-header">🚢 Titanic ML — Panel de Predicción</p>', unsafe_allow_html=True)
st.markdown(
    '<p class="sub-header">Regresión Logística (Supervivencia) y Regresión Lineal (Tarifa) · '
    'Proyecto CRISP-ML(Q)</p>',
    unsafe_allow_html=True,
)
st.divider()

# ----------------------------------------------------------------------------
# Carga de modelos
# ----------------------------------------------------------------------------
try:
    clf_model, reg_model = load_models()
    models_ok = True
except FileNotFoundError:
    models_ok = False
    st.error(
        "⚠️ No se encontraron los archivos de modelo (.pkl) en la carpeta `models/`. "
        "Ejecuta primero el notebook `notebooks/titanic_crisp_ml.ipynb` para generarlos, "
        "o corre `notebooks/_prototype.py`."
    )

# ----------------------------------------------------------------------------
# Sidebar — Datos del pasajero
# ----------------------------------------------------------------------------
st.sidebar.header("🧾 Datos del pasajero")

pclass = st.sidebar.selectbox("Clase del boleto (Pclass)", [1, 2, 3], index=2,
                               help="1 = Primera, 2 = Segunda, 3 = Tercera")
sex = st.sidebar.radio("Sexo", ["male", "female"], horizontal=True)
age = st.sidebar.slider("Edad", 0, 80, 28)
sibsp = st.sidebar.number_input("Hermanos/Cónyuge a bordo (SibSp)", 0, 8, 0)
parch = st.sidebar.number_input("Padres/Hijos a bordo (Parch)", 0, 6, 0)
embarked = st.sidebar.selectbox("Puerto de embarque", ["S", "C", "Q"],
                                 help="S = Southampton, C = Cherbourg, Q = Queenstown")
title = st.sidebar.selectbox("Título", ["Mr", "Mrs", "Miss", "Master", "Rare"])
fare_input = st.sidebar.slider("Tarifa pagada (Fare) — solo para el modelo de supervivencia",
                                0.0, 512.0, 32.0)

family_size = sibsp + parch + 1
is_alone = 1 if family_size == 1 else 0

st.sidebar.markdown(f"**Tamaño de familia calculado:** {family_size}")
st.sidebar.markdown(f"**¿Viaja solo?:** {'Sí' if is_alone else 'No'}")

predict_btn = st.sidebar.button("🔮 Predecir", type="primary", use_container_width=True)

# ----------------------------------------------------------------------------
# Cuerpo principal — Tabs
# ----------------------------------------------------------------------------
tab1, tab2, tab3 = st.tabs(["🎯 Predicción", "📊 Sobre el proyecto", "📁 Datos de entrada"])

with tab1:
    col1, col2 = st.columns(2)

    input_clf = pd.DataFrame([{
        "Pclass": pclass, "Sex": sex, "Age": age, "SibSp": sibsp, "Parch": parch,
        "Fare": fare_input, "Embarked": embarked, "FamilySize": family_size,
        "IsAlone": is_alone, "Title": title,
    }])

    input_reg = pd.DataFrame([{
        "Pclass": pclass, "Sex": sex, "Age": age, "SibSp": sibsp, "Parch": parch,
        "Embarked": embarked, "FamilySize": family_size,
    }])

    with col1:
        st.subheader("Regresión Logística — Supervivencia")
        if models_ok and predict_btn:
            pred = clf_model.predict(input_clf)[0]
            proba = clf_model.predict_proba(input_clf)[0][1]
            if pred == 1:
                st.success(f"✅ El modelo predice que el pasajero **SOBREVIVE**")
            else:
                st.error(f"❌ El modelo predice que el pasajero **NO sobrevive**")
            st.metric("Probabilidad de supervivencia", f"{proba*100:.1f}%")
            st.progress(float(proba))
        elif not models_ok:
            st.info("Carga los modelos para ver la predicción.")
        else:
            st.info("Configura los datos en la barra lateral y pulsa **Predecir**.")

    with col2:
        st.subheader("Regresión Lineal — Tarifa estimada")
        if models_ok and predict_btn:
            fare_pred = reg_model.predict(input_reg)[0]
            st.success(f"💷 Tarifa estimada: **£{fare_pred:.2f}**")
            st.metric("Tarifa estimada (Fare)", f"£{fare_pred:.2f}")
        elif not models_ok:
            st.info("Carga los modelos para ver la predicción.")
        else:
            st.info("Configura los datos en la barra lateral y pulsa **Predecir**.")

with tab2:
    st.subheader("Ciclo de vida del proyecto — CRISP-ML(Q)")
    st.markdown(
        """
1. **Business Understanding** — Definir el objetivo: predecir supervivencia y tarifa.
2. **Data Understanding** — EDA del dataset Titanic (891 pasajeros).
3. **Data Preparation** — Imputación, codificación, escalado, ingeniería de variables.
4. **Modeling** — Regresión Logística (clasificación) y Regresión Lineal (regresión).
5. **Evaluation** — Accuracy, ROC-AUC, F1 / MAE, RMSE, R².
6. **Deployment** — Esta app de Streamlit + Landing Page + GitHub.
7. **Monitoring & Maintenance** — Reentrenamiento y trazabilidad de versiones.

Consulta el cuaderno completo en `notebooks/titanic_crisp_ml.ipynb` para ver todo el proceso documentado.
        """
    )
    m1, m2, m3 = st.columns(3)
    m1.markdown('<div class="metric-card"><b>Accuracy (Clasificación)</b><br>≈ 0.85</div>', unsafe_allow_html=True)
    m2.markdown('<div class="metric-card"><b>ROC-AUC (Clasificación)</b><br>≈ 0.88</div>', unsafe_allow_html=True)
    m3.markdown('<div class="metric-card"><b>R² (Regresión)</b><br>≈ 0.38</div>', unsafe_allow_html=True)

with tab3:
    st.subheader("Vista previa de los datos que recibe cada modelo")
    st.write("**Entrada — Modelo de Clasificación (Regresión Logística):**")
    st.dataframe(input_clf, use_container_width=True)
    st.write("**Entrada — Modelo de Regresión (Regresión Lineal):**")
    st.dataframe(input_reg, use_container_width=True)

st.divider()
st.caption(
    "Proyecto académico con fines educativos. Los modelos se entrenaron sobre el dataset histórico "
    "del Titanic (1912) y no deben usarse para decisiones sobre personas reales."
)
